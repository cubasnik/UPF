{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "UPF_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "strict",
      "displayName": "Strict",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/strict",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "UPF_BUILD_TESTS": "ON",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "strict",
      "configurePreset": "strict"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "strict",
      "configurePreset": "strict",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
